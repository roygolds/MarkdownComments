{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build extension",
      "type": "shell",
      "command": "node esbuild.js",
      "options": { "cwd": "${workspaceFolder}/extension" },
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent", "panel": "shared", "clear": true }
    },
    {
      "label": "watch extension",
      "type": "shell",
      "command": "node esbuild.js --watch",
      "options": { "cwd": "${workspaceFolder}/extension" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    }
  ]
}
